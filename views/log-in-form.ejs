<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head") %>
<body>
    <h1><%= title %></h1>
    <% if (error_msg) { %>
    <p><%= error_msg %></p>
<% } %>
    <form action="/log-in" method="post">
        <label for="email">Email Address: </label>
        <input type="email" id="email" name="email" value="<%= oldInput.email || '' %>" required>
        <label for="password">Password: </label>
        <input type="password" id="password" name="password" value="<%= oldInput.password || '' %>" required>
        <button type="submit">Log In</button>
    </form>
</body>
</html>