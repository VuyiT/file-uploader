<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head") %>
<body>
    <% if (currentUser) { %>
     <h1><%= title %></h1>
    <form action="/upload-file" method="post" enctype="multipart/form-data">
        <label for="uploadedFile">Upload a File: </label>
        <input type="file" id="uploadedFile" name="uploadedFile" required>
        <button type="submit">Upload</button>
    </form>
    <% } else { %>
        <p><b>You have to have an account to upload files!</b></p>
        <nav>
            <ul>
                <li><a href="/log-in">Log In</a> if you already have an account! Or</li>
                <li><a href="/sign-up">Sign Up</a></li>
            </ul>
        </nav>
    <% } %>
</body>
</html>