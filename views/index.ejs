<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head") %>
<body>
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <% if (currentUser) { %>
                <li><a href="/log-out">Log Out</a></li>
            <% } else { %>
                <li><a href="/sign-up">Sign Up</a> if you don't have an     account. Or</li>
                <li><a href="/log-in">Log In</a></li>
            <% } %>
        </ul>
    </nav>
    <% if (currentUser) { %>
     <h1><%= title %></h1>
     <h2>Welcome <%= currentUser.firstName %>!</h2>
     <% if (locals.files && files.length > 0 || locals.folders && folders.length > 0) { %>
        <ul>
            <% folders.forEach(folder => { %>
                <li><a href="/folder/<%= folder.id %>"><%= folder.name %></a>
                    <div>
                        <a href="/folder/<%= folder.id %>/update"><button type="submit">Update Folder</button></a>
                        <form action="/folder/<%= folder.id %>/delete" method="post">
                            <button type="submit" onclick="return confirm('Deleting this folder will displace all its current files. Are you sure you want to delete this folder?')">Delete Folder</button>
                        </form>
                    </div>
                </li>
            <% }) %>
            <% files.forEach(file => { %>
                <% if (!file.folderId) { %>
                    <li><a href="/file/<%= file.id %>"><%= file.name %></a></li>
                <% } %>
            <% }) %>
        </ul>
    <% } else { %>
        <p>There are currently no files or folders in your account.</p>
     <% } %>
        <a href="/file/upload"><button type="submit">Upload File</button></a>
        <a href="/folder/create"><button type="submit">Create Folder</button></a>
    <% } else { %>
        <h1>File Storer</h1>
        <p>Here you can upload files and create new folders to store your files in. All you need to do is create an account and log in to upload!</p>
        <a href="/sign-up"><button>Get Started</button></a>
    <% } %>
</body>
</html>